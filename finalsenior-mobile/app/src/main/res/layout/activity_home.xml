<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorOnPrimary"
    android:layoutDirection="locale">

    <!-- Main Content -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorOnPrimary">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="@string/nav_home"
            app:titleTextColor="?attr/introTitleTextColor"
            app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorOnPrimary"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/top_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:background="@drawable/top_background">

                        <ImageView
                            android:id="@+id/ivProfile"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:layout_marginStart="24dp"
                            android:layout_marginTop="24dp"
                            android:background="@drawable/profile_background"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/profile" />

                        <TextView
                            android:id="@+id/textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="24dp"
                            android:text="@string/greeting"
                            android:textColor="@color/white"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@+id/ivProfile"
                            app:layout_constraintStart_toEndOf="@+id/ivProfile"
                            app:layout_constraintTop_toTopOf="@+id/ivProfile" />

                        <TextView
                            android:id="@+id/textView2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/monitoring_message"
                            android:textColor="@color/dark_gray"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/ivProfile" />

                        <!-- Monitoring Cards Layout - Inside the ConstraintLayout -->
                        <GridLayout
                            android:id="@+id/monitoringCardsLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="32dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:layout_marginBottom="16dp"
                            android:columnCount="3"
                            android:useDefaultMargins="true"
                            app:layout_constraintTop_toBottomOf="@+id/textView2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">

                            <!-- Temperature Card -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardTemperature"
                                android:layout_width="0dp"
                                android:layout_height="150dp"
                                android:layout_columnWeight="1"
                                android:layout_gravity="fill_horizontal"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                android:backgroundTint="@color/white">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:padding="12dp">

                                    <ImageView
                                        android:id="@+id/imgTemperature"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:src="@drawable/ic_temperature" />

                                    <TextView
                                        android:id="@+id/txtTemperatureValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="16dp"
                                        android:text=" -- °C"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="?attr/homeCardTextColor"/>

                                    <TextView
                                        android:id="@+id/txtTemperatureLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:text="@string/temperature"
                                        android:textSize="14sp"
                                        android:textColor="?attr/homeCardLabelColor"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Other sensor cards - apply the same pattern -->
                            <!-- Humidity Card -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardHumidity"
                                android:layout_width="0dp"
                                android:layout_height="150dp"
                                android:layout_columnWeight="1"
                                android:layout_gravity="fill_horizontal"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                android:backgroundTint="@color/white">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:padding="12dp">

                                    <ImageView
                                        android:id="@+id/imgHumidity"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:src="@drawable/ic_humidity" />

                                    <TextView
                                        android:id="@+id/txtHumidityValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="16dp"
                                        android:text=" -- %"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="?attr/homeCardTextColor"/>

                                    <TextView
                                        android:id="@+id/txtHumidityLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:text="@string/humidity"
                                        android:textSize="14sp"
                                        android:textColor="?attr/homeCardLabelColor"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Water Card -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardWater"
                                android:layout_width="0dp"
                                android:layout_height="150dp"
                                android:layout_columnWeight="1"
                                android:layout_gravity="fill_horizontal"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                android:backgroundTint="@color/white">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:padding="12dp">

                                    <ImageView
                                        android:id="@+id/imgWater"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:src="@drawable/ic_water" />

                                    <TextView
                                        android:id="@+id/txtWaterValue"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="16dp"
                                        android:text=" -- "
                                        android:textSize="14sp"
                                        android:layout_width="match_parent"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:textColor="?attr/homeCardTextColor"/>

                                    <TextView
                                        android:id="@+id/txtWaterLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:text="@string/water"
                                        android:textSize="14sp"
                                        android:textColor="?attr/homeCardLabelColor"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Fire Card -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardFire"
                                android:layout_width="0dp"
                                android:layout_height="150dp"
                                android:layout_columnWeight="1"
                                android:layout_gravity="fill_horizontal"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                android:backgroundTint="@color/white">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:padding="12dp">

                                    <ImageView
                                        android:id="@+id/imgFire"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:src="@drawable/ic_fire" />

                                    <TextView
                                        android:id="@+id/txtFireValue"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="16dp"
                                        android:text=" -- "
                                        android:textSize="14sp"
                                        android:layout_width="match_parent"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:textColor="?attr/homeCardTextColor"/>

                                    <TextView
                                        android:id="@+id/txtFireLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:text="@string/fire"
                                        android:textSize="14sp"
                                        android:textColor="?attr/homeCardLabelColor"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Gas Card -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardGas"
                                android:layout_width="0dp"
                                android:layout_height="150dp"
                                android:layout_columnWeight="1"
                                android:layout_gravity="fill_horizontal"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                android:backgroundTint="@color/white">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:padding="12dp">

                                    <ImageView
                                        android:id="@+id/imgGas"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:src="@drawable/ic_gas" />

                                    <TextView
                                        android:id="@+id/txtGasValue"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="16dp"
                                        android:text=" -- "
                                        android:textSize="14sp"
                                        android:layout_width="match_parent"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:textColor="?attr/homeCardTextColor"/>

                                    <TextView
                                        android:id="@+id/txtGasLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:text="@string/gas"
                                        android:textSize="14sp"
                                        android:textColor="?attr/homeCardLabelColor"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Motion Card -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardMotion"
                                android:layout_width="0dp"
                                android:layout_height="150dp"
                                android:layout_columnWeight="1"
                                android:layout_gravity="fill_horizontal"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                android:backgroundTint="@color/white">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:padding="12dp">

                                    <ImageView
                                        android:id="@+id/imgMotion"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:src="@drawable/ic_motion" />

                                    <TextView
                                        android:id="@+id/txtMotionValue"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="16dp"
                                        android:text=" -- "
                                        android:textSize="14sp"
                                        android:layout_width="match_parent"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:textColor="?attr/homeCardTextColor"/>

                                    <TextView
                                        android:id="@+id/txtMotionLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:text="@string/motion"
                                        android:textSize="14sp"
                                        android:textColor="?attr/homeCardLabelColor"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>
                        </GridLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Smart Room Controls Grid Layout -->
                    <GridLayout
                        android:id="@+id/controls_grid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:columnCount="2"
                        android:useDefaultMargins="true">

                        <!-- - LIGHT CARD - -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardLight"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            android:backgroundTint="?attr/homeControlCardColor">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <ImageView
                                    android:id="@+id/imgLight"
                                    android:layout_width="45dp"
                                    android:layout_height="45dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_light" />

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/switchLight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentTop="true"
                                    android:layout_alignParentEnd="true"
                                    app:thumbTint="@color/switch_thumb_color"
                                    app:trackTint="@color/switch_track_color" />

                                <TextView
                                    android:id="@+id/txtLight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/imgLight"
                                    android:layout_marginTop="16dp"
                                    android:text="@string/light"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/homeControlTextColor"/>

                                <!-- STATUS -->
                                <TextView
                                    android:id="@+id/txtLightStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_toEndOf="@id/txtLight"
                                    android:layout_alignBaseline="@id/txtLight"
                                    android:layout_marginStart="20dp"
                                    android:text="OFF"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/homeControlTextColor"/>
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>

                        <!--- FAN CARD -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardFan"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            android:backgroundTint="?attr/homeControlCardColor">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <ImageView
                                    android:id="@+id/imgFan"
                                    android:layout_width="45dp"
                                    android:layout_height="45dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_fan" />

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/switchFan"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentTop="true"
                                    android:layout_alignParentEnd="true"
                                    app:thumbTint="@color/switch_thumb_color"
                                    app:trackTint="@color/switch_track_color" />

                                <TextView
                                    android:id="@+id/txtFan"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/imgFan"
                                    android:layout_marginTop="16dp"
                                    android:text="@string/fan"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/homeControlTextColor"/>

                                <!-- STATUS -->
                                <TextView
                                    android:id="@+id/txtFanStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_toEndOf="@id/txtFan"
                                    android:layout_alignBaseline="@id/txtFan"
                                    android:layout_marginStart="20dp"
                                    android:text="OFF"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/homeControlTextColor"/>
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- - DOOR CARD - -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardDoor"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            android:backgroundTint="?attr/homeControlCardColor">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <ImageView
                                    android:id="@+id/imgDoor"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_door" />

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/switchDoor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentTop="true"
                                    android:layout_alignParentEnd="true"
                                    app:thumbTint="@color/switch_thumb_color"
                                    app:trackTint="@color/switch_track_color" />

                                <TextView
                                    android:id="@+id/txtDoor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/imgDoor"
                                    android:layout_marginTop="16dp"
                                    android:text="@string/door"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/homeControlTextColor"/>

                                <!-- STATUS -->
                                <TextView
                                    android:id="@+id/txtDoorStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_toEndOf="@id/txtDoor"
                                    android:layout_alignBaseline="@id/txtDoor"
                                    android:layout_marginStart="20dp"
                                    android:text="CLOSE"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/homeControlTextColor"/>
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- - CAMERA CARD - -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardCamera"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            android:backgroundTint="?attr/homeControlCardColor">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <ImageView
                                    android:id="@+id/imgCamera"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_camera" />

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/switchCamera"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentTop="true"
                                    android:layout_alignParentEnd="true"
                                    app:thumbTint="@color/switch_thumb_color"
                                    app:trackTint="@color/switch_track_color" />

                                <TextView
                                    android:id="@+id/txtCamera"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/imgCamera"
                                    android:layout_marginTop="16dp"
                                    android:text="@string/camera"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/homeControlTextColor"/>
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>

                    </GridLayout>

                </LinearLayout>
            </ScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ============ NAV DRAWER ============ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
