<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Finalsenior" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/purple</item>
        <item name="colorOnPrimary">@color/Dark_purple</item>
        <item name="colorSecondaryVariant">@color/purple</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:colorBackground">@color/Dark_purple</item>
        <item name="android:windowBackground">@color/Dark_purple</item>
        <item name="android:textColor">@color/white</item>
        <item name="constraintLayoutBackground">@color/Dark_purple</item>
        <item name="cardViewStyle">@style/CustomCardView</item>
        <item name="colorSurface">@color/card_background_dark</item>

        <!-- Text colors for intro screen -->
        <item name="introTitleTextColor">@color/white</item>
        <item name="introSubtitleTextColor">@color/light_gray</item>
        <item name="introButtonTextColor">@color/white</item>

        <!-- Login-specific colors -->
        <item name="loginEditTextColor">@color/white</item>
        <item name="loginEditTextHintColor">@color/light_gray</item>

        <!-- Home screen colors -->
        <item name="homeCardTextColor">@color/purple_light</item>
        <item name="homeCardLabelColor">@color/dark_gray</item>
        <item name="homeControlCardColor">@color/white</item>
        <item name="homeControlTextColor">@color/black</item>

        <!-- Logs-specific colors -->
        <item name="logsScreenBackground">@color/Dark_purple</item>
        <item name="logsCardBackground">@color/purple_light</item>
        <item name="logsCardTextColor">@color/white</item>
        <item name="logsCardTimestampColor">@color/dark_gray</item>

        <!-- Notifications-specific attributes -->
        <item name="notificationCardBackground">@color/card_background_dark</item>
        <item name="notificationTextColor">@color/white</item>
        <item name="notificationTimeColor">@color/light_gray</item>

        <!-- Settings-specific attributes -->
        <item name="settingsTitleTextColor">@color/Dark_purple</item>
        <item name="settingsOptionTextColor">@color/black</item>

        <!-- Add to the existing Theme.Finalsenior style -->
        <item name="navigationViewStyle">@style/Widget.App.NavigationView</item>

        <!-- Add to your dark theme in themes.xml (night) -->
        <item name="spinnerDropdownTextColor">@color/purple_light</item>
    </style>
</resources>